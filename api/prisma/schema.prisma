generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Material {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  unit      String
  unitPrice Float
  currency  String   @default("TRY")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Project {
  id           Int          @id @default(autoincrement())
  userId       Int

  name         String?
  buildingType BuildingType

  lengthM      Float
  widthM       Float
  heightM      Float

  hasCraneBeam  Boolean    @default(false)

  hasLoadingRamp Boolean   @default(false)
  rampCount     Int        @default(0)

  doorCount     Int        @default(1)

  baySpacingM   Float
  hallCount     Int
  hallWidthM    Float

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user         User        @relation(fields: [userId], references: [id])
  modelRuns ModelRun[]
}

enum BuildingType {
  STEEL_FULL
  RC_COL_STEEL_ROOF
  RC_FULL_PRECAST
}


model ModelRun {
  id            Int      @id @default(autoincrement())
  projectId     Int
  version       Int
  engineVersion String   @default("v1")
  createdAt     DateTime @default(now())

  project       Project  @relation(fields: [projectId], references: [id])
  elements      ModelElement[]
}

model ModelElement {
  id          Int      @id @default(autoincrement())
  modelRunId  Int

  elementType String   // COLUMN/BEAM/PANEL/DOOR/RAMP...
  material    String   // "celik", "beton", "panel" gibi (Materials.name ile aynı olsun)

  qty         Float    // miktar (ton / m2 / m3) -> unit elementType'a göre anlaşılır
  unit        String   // "ton" | "m2" | "m3" | "adet" (basit)

  // 3D için basit geometri (parametrik)
  geomType    String   // "box" | "line"
  geom        Json     // { ... } -> box ölçüleri / line noktaları

  createdAt   DateTime @default(now())

  modelRun    ModelRun @relation(fields: [modelRunId], references: [id])
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  admin
  investor
  contractor
}

enum ContractorType {
  TAXED
  UNTAXED
}

enum InvestorAccessStatus {
  PENDING
  ACCEPT
  REJECT
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  phone     String?  @unique
  password  String
  createdAt DateTime @default(now())
  isDualMember Boolean @default(false)

  // ✅ güncelle
  role      UserRole   @default(contractor)
  status    UserStatus @default(APPROVED)

  projects  Project[]

  investorProfile   InvestorProfile?
  contractorProfile ContractorProfile?
  emailVerificationTokens EmailVerificationToken[]

  listingsAsInvestor Listing[] @relation("InvestorListings")
  bidsAsContractor   Bid[]     @relation("ContractorBids")
}

model EmailVerificationToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InvestorProfile {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique

  companyName   String?
  contactName   String?
  phone         String?
  marketAccessStatus InvestorAccessStatus @default(PENDING)

  // senin kuralın: official company mail + kısa yatırım metni
  officialCompanyEmail String?
  investmentSummary    String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
}

model ContractorProfile {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique

  contractorType ContractorType @default(UNTAXED)

  companyName    String?
  ownerName      String?

  // ✅ zorunlu foto: backend validation ile şart koşacağız
  ownerPhotoUrl  String?

  about          String?
  servicesText   String? // yaptığı faaliyetler/işler listesi kısa metin

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
  references    Reference[]
  media         Media[]
  workItems     WorkItem[]
}

model Listing {
  id          Int      @id @default(autoincrement())
  investorId  Int

  title       String
  description String?

  // bina özellikleri (minimum)
  buildingType BuildingType
  lengthM      Float
  widthM       Float
  heightM      Float

  locationCity String?
  locationNote String?

  status      String   @default("OPEN") // OPEN/CLOSED basit kalsın

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  investor    User     @relation("InvestorListings", fields: [investorId], references: [id])
  bids        Bid[]
}

model Bid {
  id           Int      @id @default(autoincrement())
  listingId    Int
  contractorId Int

  priceTRY     Float?
  durationDays Int?
  message      String?

  status       String   @default("SENT") // SENT/ACCEPTED/REJECTED basit kalsın

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listing      Listing  @relation(fields: [listingId], references: [id])
  contractor   User     @relation("ContractorBids", fields: [contractorId], references: [id])

  @@unique([listingId, contractorId]) // aynı ilana 2 teklif veremesin (istersen kaldırırız)
}

model WorkItem {
  id          Int      @id @default(autoincrement())
  contractorProfileId Int

  title       String
  description String?

  createdAt   DateTime @default(now())

  contractorProfile ContractorProfile @relation(fields: [contractorProfileId], references: [id])
}

model Reference {
  id          Int      @id @default(autoincrement())
  contractorProfileId Int

  companyName String?
  personName  String
  phone       String?
  email       String?

  createdAt   DateTime @default(now())

  contractorProfile ContractorProfile @relation(fields: [contractorProfileId], references: [id])
}

model Media {
  id          Int      @id @default(autoincrement())
  contractorProfileId Int

  type        String   // "photo" | "video"
  url         String
  caption     String?

  createdAt   DateTime @default(now())

  contractorProfile ContractorProfile @relation(fields: [contractorProfileId], references: [id])
}
